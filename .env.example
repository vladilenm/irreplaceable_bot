BOT_TOKEN=
TARGET_CHAT_ID=
AI_RADAR_THREAD_ID=
# Cron expressions are evaluated in container TZ=UTC. MSK comments below
# show the rendering of the *default* value (UTC+3); change the value and
# the comment is no longer accurate.
# DIGEST_CRON — default = 09:00 MSK (06:00 UTC).
DIGEST_CRON=0 6 * * *
AI_API_KEY=
AI_MODEL=claude-sonnet-4-20250514
# Для OpenAI-совместимых провайдеров (DeepSeek и т.п.). Оставь пустым для официального OpenAI.
# AI_BASE_URL=https://api.deepseek.com/v1
AI_BASE_URL=
LOG_LEVEL=info
NODE_ENV=development

# v2.0 thread summaries
THREAD_SUMMARY_THREAD_ID=
# THREAD_SUMMARY_CRON — evaluated in container TZ=UTC. Default = 06:30 MSK (03:30 UTC).
THREAD_SUMMARY_CRON=30 3 * * *
MESSAGE_RETENTION_DAYS=90
# RETENTION_SWEEP_CRON — evaluated in container TZ=UTC. Default = 04:00 MSK (01:00 UTC).
RETENTION_SWEEP_CRON=0 1 * * *
DB_PATH=data/messages.db
# CSV of message_thread_id values to seed tracked_threads on first boot only.
# After Phase 5 ships /track/untrack, this can be left blank.
INITIAL_TRACKED_THREAD_IDS=
